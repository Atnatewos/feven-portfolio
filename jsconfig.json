{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["./components/*", "./src/components/*"],
      "@/lib/*": ["./lib/*", "./src/lib/*"],
      "@/config/*": ["./config/*", "./src/config/*"],
      "@/styles/*": ["./styles/*", "./src/styles/*"],
      "@/*": ["./src/*", "./*"]
    }
  },
  "exclude": ["node_modules", ".next", "out"]
}