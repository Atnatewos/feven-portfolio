{
  "sectionTitle": "Social Media & Contact",
  "sectionDescription": "Add your social media profiles and contact details. Each platform you fill in will appear as a beautiful, clickable card on the public Contact page. Only platforms with both a URL and display name will be shown to visitors. Phone numbers only need the number — no display name required.",
  "platforms": [
