      "id": "phone",
      "label": "Phone",
      "icon": "📞",
      "urlPlaceholder": "+251 912 345 678, +251 911 234 567",
      "urlLabel": "Phone Number(s)",
      "prefix": "tel:",
      "pattern": "^\\+?[0-9\\s\\-(),]{7,20}$",
      "allowMultiple": true,
      "helpText": "Add one or more phone numbers separated by commas. Include country code. The number itself is displayed — no separate display name needed.",
      "showDisplayName": false
    },
    {
      "id": "email",
      "label": "Email",
